{
  "name": "vr-player",
  "version": "0.1.0",
  "description": "A lightweight 360° panoramic video VR player built with pure WebGL. Zero runtime dependencies.",
  "type": "module",
  "license": "MIT",
  "author": "",
  "homepage": "https://gitlab.vzan.com/front-end/vr-player",
  "repository": {
    "type": "git",
    "url": "git+https://gitlab.vzan.com/front-end/vr-player.git"
  },
  "bugs": {
    "url": "https://gitlab.vzan.com/front-end/vr-player/issues"
  },
  "keywords": ["vr", "360", "panorama", "video", "webgl", "player"],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "dev": "rolldown -c rolldown.config.ts --watch",
    "build": "rolldown -c rolldown.config.ts && tsc --emitDeclarationOnly",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "demo": "vite demo --host",
    "demo:https": "node scripts/serve-https.js",
    "gen-cert": "node scripts/gen-cert.js",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish",
    "ci": "biome check . && vitest run && rolldown -c rolldown.config.ts",
    "prepare": "husky"
  },
  "packageManager": "pnpm@9.15.0",
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.27.9",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "rolldown": "^1.0.0-beta.1",
    "selfsigned": "^5.5.0",
    "typescript": "^5.7.0",
    "vite": "^8.1.1",
    "vitest": "^2.1.0"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json}": "biome check --write"
  }
}
